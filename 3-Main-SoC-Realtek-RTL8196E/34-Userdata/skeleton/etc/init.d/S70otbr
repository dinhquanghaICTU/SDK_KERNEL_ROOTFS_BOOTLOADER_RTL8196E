#!/bin/sh
# S70otbr — Start OpenThread Border Router agent
#
# Requires:
#   - Kernel with IPv6 + CONFIG_FILE_LOCKING
#   - EFR32 flashed with OT-RCP firmware
#   - otbr-agent binary in /userdata/usr/bin/
#
# Storage:
#   otbr-agent runs from tmpfs (/tmp/thread) to protect JFFS2 from flash
#   wear (frame counters update ~480 times/day). A background daemon polls
#   the active dataset every 30s and syncs to flash (/userdata/thread) only
#   when the dataset changes. On clean shutdown (SIGTERM), a final sync runs.
#   On power loss, only frame counters are lost — OpenThread recovers by
#   jumping ahead on next boot.

OTBR_BIN="/userdata/usr/bin/otbr-agent"

# UART settings — must match EFR32 OT-RCP firmware.
# Baud is read from /userdata/etc/radio.conf (FIRMWARE_BAUD= key, the chip-side
# truth written by flash_efr32.sh on every successful flash) so the OT-RCP
# firmware-baud and the host-side spinel client always agree. Fall back to
# legacy OTBR_BAUD for configs migrated from v3.0.x that pre-date the
# single-key cleanup.
# Default to 460800 (the historical OT-RCP build baud) if the key is absent.
FW_BAUD=460800
if [ -f /userdata/etc/radio.conf ]; then
    # Use 'tail -1' so duplicate keys (from manual edits or stale migrations)
    # resolve to the last value rather than the first.
    val=$(grep '^FIRMWARE_BAUD=' /userdata/etc/radio.conf | tail -1 | cut -d= -f2)
    [ -z "$val" ] && val=$(grep '^OTBR_BAUD=' /userdata/etc/radio.conf | tail -1 | cut -d= -f2)
    case "$val" in
        115200|230400|460800|691200|892857) FW_BAUD="$val" ;;
    esac
fi
# uart-flow-control=true is REQUIRED on this SoC: it tells otbr-agent to set
# CRTSCTS on the tty, which the 8250 core then propagates as MCR_AFE on the
# 16550A. Without it, the gateway runs without hardware RTS/CTS and the RX
# FIFO can overrun under bursty Spinel traffic at 460800 (#89).
RCP_URL="spinel+hdlc+uart:///dev/ttyS1?uart-baudrate=${FW_BAUD}&uart-flow-control=true"

# Network interfaces
THREAD_IF="wpan0"
BACKBONE_IF="eth0"

# REST API — listen on all interfaces so HA can reach it
REST_LISTEN="::0"
REST_PORT="8081"

# Storage paths
FLASH_DIR="/userdata/thread"
RAM_DIR="/tmp/thread"

# Supervision (issue #109): otbr-agent and the housekeeping monitor are each
# run under `keepalive`, a tiny C supervisor that restarts them on exit and
# forwards SIGTERM for a clean stop. This makes OTBR self-heal from an agent
# crash / RCP fault and from a busybox-ash SIGSEGV in the monitor loop, neither
# of which used to recover. keepalive PIDs are tracked so stop can terminate
# the supervisors (not just the children — killing a child alone would only
# trigger a restart).
KEEPALIVE="/usr/sbin/keepalive"
OTBR_MONITOR="/usr/sbin/otbr-monitor"
OTBR_SUP_PID="/tmp/otbr-agent.sup.pid"
MON_SUP_PID="/tmp/otbr-monitor.sup.pid"
SRP_DONE_FLAG="/tmp/otbr-srp-recovery.done"

case "$1" in
start)
    [ -x "$OTBR_BIN" ] || exit 0

    # Only start if radio mode is set to "otbr" in /userdata/etc/radio.conf
    if ! [ -f /userdata/etc/radio.conf ] || ! grep -q '^MODE=otbr' /userdata/etc/radio.conf; then
        exit 0
    fi

    echo "Starting otbr-agent..."

    # Restore settings from flash to tmpfs
    mkdir -p "$FLASH_DIR" "$RAM_DIR"
    cp "$FLASH_DIR"/* "$RAM_DIR"/ 2>/dev/null

    # Enable IPv6 forwarding (required for border routing)
    echo 1 > /proc/sys/net/ipv6/conf/all/forwarding
    # Accept Router Advertisements even with forwarding enabled (default drops
    # to 0 when forwarding=1), so the gateway can acquire a GUA via SLAAC
    echo 2 > /proc/sys/net/ipv6/conf/eth0/accept_ra

    # Clear the once-per-boot SRP recovery flag (tmpfs may survive a `restart`).
    rm -f "$SRP_DONE_FLAG"

    # Supervise otbr-agent under keepalive: restart on crash / RCP fault.
    # Post-start tuning (log level, TX power) is owned by otbr-monitor so it
    # re-applies on every restart, not just the first launch.
    "$KEEPALIVE" -n otbr-agent \
        "$OTBR_BIN" \
        -d 4 \
        -I "$THREAD_IF" \
        -B "$BACKBONE_IF" \
        --rest-listen-address "$REST_LISTEN" \
        --rest-listen-port "$REST_PORT" \
        --vendor-name "Lidl" \
        --model-name "Silvercrest" \
        --data-path "$RAM_DIR" \
        "$RCP_URL" &
    echo $! > "$OTBR_SUP_PID"

    # Supervise the housekeeping monitor (radio tuning, status LED, dataset
    # sync, one-shot SRP recovery) under keepalive, so a busybox-ash crash in
    # its long-lived loop is recovered instead of silently stopping it.
    "$KEEPALIVE" -n otbr-monitor "$OTBR_MONITOR" &
    echo $! > "$MON_SUP_PID"
    ;;

stop)
    echo "Stopping otbr-agent..."
    # Stop the supervisors first. keepalive forwards SIGTERM to its child and
    # exits WITHOUT restarting; killing a child directly would only trigger a
    # keepalive restart, so the order matters.
    for pidf in "$OTBR_SUP_PID" "$MON_SUP_PID"; do
        [ -f "$pidf" ] && kill "$(cat "$pidf")" 2>/dev/null
        rm -f "$pidf"
    done
    # Give keepalive a moment to forward SIGTERM and reap its child.
    sleep 1
    # Fallback: clean up an orphaned agent if a supervisor was already gone.
    killall otbr-agent 2>/dev/null
    # Reset LED (also done by otbr-monitor's TERM trap)
    echo 0 > /sys/class/leds/status/brightness
    ;;

restart)
    $0 stop
    sleep 1
    $0 start
    ;;

*)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0
