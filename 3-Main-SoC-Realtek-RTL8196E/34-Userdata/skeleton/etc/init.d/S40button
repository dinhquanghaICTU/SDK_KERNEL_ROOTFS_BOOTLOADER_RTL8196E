#!/bin/sh
#
# S40button — front-panel button daemon (long-press → recover EFR32 radio)
#
# Thin wrapper around /usr/sbin/s40button.  The actual polling logic is
# implemented in C (./34-Userdata/s40button/src/s40button.c) — replaces
# the v3.2.x/v3.3.0 busybox shell loop, which had an intermittent
# SIGSEGV in busybox after some hours of idle polling.
#
# See:
#   - 34-Userdata/s40button/src/s40button.c (source + behaviour)
#   - 2-Zigbee-Radio-Silabs-EFR32/POST-MORTEM-bootloader-recovery.md
#

S40_BIN=/usr/sbin/s40button
PIDFILE=/var/run/S40button.pid
LOGTAG=S40button

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "S40button: already running (pid $(cat "$PIDFILE"))"
        return 0
    fi
    if [ ! -x "$S40_BIN" ]; then
        echo "S40button: $S40_BIN not found or not executable" >&2
        logger -t "$LOGTAG" "missing binary $S40_BIN, not starting"
        return 1
    fi
    echo "S40button: starting daemon ($S40_BIN)..."
    "$S40_BIN" &
    echo $! > "$PIDFILE"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null
        rm -f "$PIDFILE"
        echo "S40button: stopped (pid $pid)"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 0.5; start ;;
    *)       echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
