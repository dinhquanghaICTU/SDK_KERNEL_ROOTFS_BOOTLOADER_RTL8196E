--- a/kernel/time/hrtimer.c
+++ b/kernel/time/hrtimer.c
@@ -1061,6 +1061,37 @@
 EXPORT_SYMBOL_GPL(hrtimer_forward);
 
 /*
+ * hrtimer_collect_pending_fns - collect .function pointers of active hrtimers
+ * on this CPU, earliest-expiry first per clock base, up to @max; returns the
+ * count. Companion to timer_collect_pending_fns() for the RTL8196E watchdog
+ * panic notifier: names the source of an HRTIMER_SOFTIRQ storm (issue #99).
+ * Cold path only (panic context). The active watchdog hrtimer
+ * (watchdog_timer_fn) and the tick handler will appear — expected noise; the
+ * storming entry is the one that recurs across captures. UP SoC, preemption
+ * already off in the panic path, so raw_cpu_ptr() is safe.
+ */
+int hrtimer_collect_pending_fns(void **out, int max)
+{
+	struct hrtimer_cpu_base *cb = raw_cpu_ptr(&hrtimer_bases);
+	int i, n = 0;
+
+	for (i = 0; i < HRTIMER_MAX_CLOCK_BASES && n < max; i++) {
+		struct hrtimer_clock_base *base = &cb->clock_base[i];
+		struct timerqueue_node *node;
+
+		for (node = timerqueue_getnext(&base->active);
+		     node && n < max;
+		     node = timerqueue_iterate_next(node)) {
+			struct hrtimer *t = container_of(node, struct hrtimer, node);
+
+			out[n++] = (void *)ACCESS_PRIVATE(t, function);
+		}
+	}
+	return n;
+}
+EXPORT_SYMBOL_GPL(hrtimer_collect_pending_fns);
+
