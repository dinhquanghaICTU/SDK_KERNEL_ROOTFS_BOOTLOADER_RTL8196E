instance_name: cpcd_bringup
# Native TCP bus: cpcd dials the gateway's in-kernel UART<->TCP bridge directly
# and owns its own reconnection. No socat PTY shim. The UART baud lives on the
# gateway side (the bridge), so the host does not set it here.
bus_type: TCP
tcp_server_address: 192.168.1.100
tcp_server_port: 8888
disable_encryption: true
binding_key_file: /home/jnilo/.cpcd/binding.key
stdout_trace: false
trace_to_file: false
traces_folder: /run/user/1000/rcp-stack/traces
# No socket_folder key: cpcd v4.5.3 ignores it (warns "not recognized") and
# derives /dev/shm/cpcd/<instance_name>/ from the compiled-in CPC_SOCKET_DIR.
