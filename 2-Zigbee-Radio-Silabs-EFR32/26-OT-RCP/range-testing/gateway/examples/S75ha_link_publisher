#!/bin/sh
#
# S75ha_link_publisher — opt-in HA link-quality publisher
#
# Thin init wrapper around /usr/bin/ha_link_publisher.sh. Auto-starts
# the daemon at boot if a config file is present at
# /userdata/etc/ha_link_publisher.conf — otherwise silently skips, so
# this script is harmless on a gateway that doesn't use the publisher.
#
# Runs after S70otbr because the publisher needs `ot-ctl` to be
# functional (otbr-agent must be running). The publisher tolerates
# otbr not yet being fully up on the first cycle (just emits a
# zero-attached cycle); the next 60s cycle will have it ready.
#
# Installation (per-gateway, not part of the default rootfs):
#
#   scp -O examples/S75ha_link_publisher root@<gateway>:/userdata/etc/init.d/
#   ssh root@<gateway> 'chmod +x /userdata/etc/init.d/S75ha_link_publisher'
#
# Then create /userdata/etc/ha_link_publisher.conf from the template
# `gateway/ha_link_publisher.conf.example` and the publisher will start
# at every boot.
#
# This script is intentionally NOT shipped in the default rootfs
# skeleton — it is an opt-in convenience for users who want the
# publisher to auto-restart after a reboot.

PUB=/usr/bin/ha_link_publisher.sh
CONF=/userdata/etc/ha_link_publisher.conf

case "$1" in
    start)
        [ -x "$PUB" ] || exit 0
        [ -f "$CONF" ] || exit 0
        echo "Starting ha_link_publisher..."
        "$PUB" start
        ;;
    stop)
        [ -x "$PUB" ] || exit 0
        echo "Stopping ha_link_publisher..."
        "$PUB" stop
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        [ -x "$PUB" ] || { echo "publisher not installed"; exit 0; }
        "$PUB" status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}" >&2
        exit 1
        ;;
esac
exit 0
